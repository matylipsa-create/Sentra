# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# IDE and editors
.idea/
.vscode/*
!.vscode/extensions.json

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Vite / TypeScript build artifacts
dist/
dist
dist-ssr
*.tsbuildinfo
next-env.d.ts

# Production builds
/build

# Environment files
.env
.env.*
*.env
*.local
credentials.json
*token.json*
*credentials.json*
*.key
.credentials

# Logs and debug files
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-debug.log*
lerna-debug.log*
dump.rdb

# System files
.DS_Store
*.pem
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Python (legacy artifacts — no longer applicable but harmless)
__pycache__/
*pyc*
venv/
.venv/

# Deployment
.vercel

# Archive files and large assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/

# Mobile development
android-sdk/
